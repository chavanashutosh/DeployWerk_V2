# Build from repository root: docker build -f docker/Dockerfile.web .
FROM node:22-bookworm AS webbuild
WORKDIR /build

COPY web/package.json web/package-lock.json ./web/
RUN cd web && npm ci

COPY web ./web

WORKDIR /build/web
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=webbuild /build/web/dist /usr/share/nginx/html
COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
