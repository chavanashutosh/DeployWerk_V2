# Copy to the native DeployWerk host env (for example `/etc/deploywerk/deploywerk.env`).
# Full list: DeployWerk_V2 repository root `.env.example`

DEPLOYWERK_PUBLIC_APP_URL=https://app.orbytals.com
DEPLOYWERK_API_URL=https://api.orbytals.com
DEPLOYWERK_EDGE_MODE=traefik
# Must match the external Docker network Traefik uses (this edge stack: `proxy`).
DEPLOYWERK_TRAEFIK_DOCKER_NETWORK=proxy
DEPLOYWERK_APPS_BASE_DOMAIN=orbytals.com

# API on loopback when native; nginx SPA + /api proxy (Traefik → 172.17.0.1:8085).
HOST=localhost
PORT=8080

# SMTP (Mailcow Docker stack on the same host)
# DEPLOYWERK_SMTP_HOST=localhost
# DEPLOYWERK_SMTP_PORT=587
# ...

# Native host integrations usually point at host-local services rather than
# `host.docker.internal`.
DEPLOYWERK_DEFAULT_STORAGE_ENDPOINT_URL=http://localhost:3900
DEPLOYWERK_DEFAULT_STORAGE_REGION=garage
DEPLOYWERK_INTEGRATION_TRAEFIK_URL=http://localhost:18080
DEPLOYWERK_INTEGRATION_MAILCOW_URL=https://mail.orbytals.com
DEPLOYWERK_LOCAL_SERVICE_DEFAULTS=true
VITE_API_URL=
DEPLOYWERK_API_PROXY=http://localhost:8080
