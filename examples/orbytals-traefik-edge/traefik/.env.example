# Copy to .env next to docker-compose.yml
ACME_EMAIL=postmaster@orbytals.com

# Let's Encrypt ACME directory (production). Staging only for debugging rate limits:
# TRAEFIK_ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory
TRAEFIK_ACME_CASERVER=https://acme-v02.api.letsencrypt.org/directory

# Docker network Traefik joins (must exist). Match your compose external network name (default proxy).
# TRAEFIK_PUBLIC_NETWORK=proxy

# Host file holding Let's Encrypt data (mounted into container as /acme.json).
# Default in compose file: /opt/traefik/acme/acme.json
# ACME_JSON_HOST_PATH=/opt/orbytals/edge/traefik/acme/acme.json
