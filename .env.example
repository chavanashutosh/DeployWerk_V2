APP_ENV=development
SEED_DEMO_USERS=true
DEMO_LOGINS_PUBLIC=true
ALLOW_LOCAL_PASSWORD_AUTH=true

HOST=127.0.0.1
PORT=8080
RUST_LOG=deploywerk_api=info,tower_http=info,sqlx=warn

DATABASE_URL=postgresql://deploywerk:deploywerk@127.0.0.1:5432/deploywerk
DATABASE_MAX_CONNECTIONS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000

JWT_SECRET=nL4qK8vR2mP9sT5wX1yZ6aB3cD7eF0gH4jM8nQ2rS5tU9vW1xY4zA6bC8dE2fG5h
SERVER_KEY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

DEPLOYWERK_API_URL=http://127.0.0.1:8080
DEPLOYWERK_GIT_SHA=local
DEPLOYWERK_GIT_CACHE_ROOT=/var/lib/deploywerk/git-cache
DEPLOYWERK_VOLUMES_ROOT=/var/lib/deploywerk/volumes

DEPLOYWERK_MINIO_ROOT_USER=deploywerk
DEPLOYWERK_MINIO_ROOT_PASSWORD=deploywerk-dev-only-change-me
DEPLOYWERK_MINIO_BUCKET=deploywerk

DEPLOYWERK_DEFAULT_STORAGE_ENDPOINT_URL=http://minio:9000
DEPLOYWERK_DEFAULT_STORAGE_BUCKET=deploywerk
DEPLOYWERK_DEFAULT_STORAGE_REGION=us-east-1
DEPLOYWERK_DEFAULT_STORAGE_PATH_STYLE=true
DEPLOYWERK_DEFAULT_STORAGE_ACCESS_KEY=deploywerk
DEPLOYWERK_DEFAULT_STORAGE_SECRET_KEY=deploywerk-dev-only-change-me

DEPLOYWERK_PLATFORM_DOCKER_ENABLED=true
DEPLOYWERK_APPS_BASE_DOMAIN=apps.local
DEPLOYWERK_EDGE_MODE=traefik
DEPLOYWERK_TRAEFIK_DOCKER_NETWORK=traefik
DEPLOYWERK_APP_CONTAINER_PORT=8080
DEPLOYWERK_PR_PREVIEW_ISOLATED_NETWORK=false

DEPLOYWERK_DEPLOY_DISPATCH=inline
DEPLOYWERK_WORKER_POLL_MS=2000

DEPLOYWERK_SMTP_HOST=host.docker.internal
DEPLOYWERK_SMTP_PORT=587
DEPLOYWERK_SMTP_USER=deploywerk@mail.local
DEPLOYWERK_SMTP_PASSWORD=ReplaceWithMailcowGeneratedMailboxPassword
DEPLOYWERK_SMTP_FROM=DeployWerk <deploywerk@mail.local>
DEPLOYWERK_SMTP_TLS=starttls
DEPLOYWERK_PUBLIC_APP_URL=http://127.0.0.1:5173
DEPLOYWERK_ADMIN_ACTION_EMAILS=false
DEPLOYWERK_MAIL_ENABLED=false

VITE_PRICING_REQUIRES_AUTH=false
# Production behind nginx/Traefik should usually leave this empty to use same-origin `/api`.
VITE_API_URL=http://127.0.0.1:8080
DEPLOYWERK_API_PROXY=http://127.0.0.1:8080

DEPLOYWERK_LOCAL_SERVICE_DEFAULTS=false
DEPLOYWERK_INTEGRATION_TRAEFIK_URL=http://host.docker.internal:8080
DEPLOYWERK_INTEGRATION_PORTAINER_URL=https://host.docker.internal:9443
DEPLOYWERK_INTEGRATION_FORGEJO_URL=http://host.docker.internal:3000
DEPLOYWERK_INTEGRATION_TECHNITIUM_URL=http://host.docker.internal:5380
DEPLOYWERK_INTEGRATION_MAILCOW_URL=https://host.docker.internal:8444
DEPLOYWERK_INTEGRATION_MATRIX_CLIENT_URL=http://host.docker.internal:8008

DEPLOYWERK_DOCUMENTATION_BASE_URL=https://github.com/chavanashutosh/DeployWerk_V2/blob/main

DEPLOYWERK_TECHNITIUM_DNS_ENABLED=false
DEPLOYWERK_TECHNITIUM_API_URL=http://host.docker.internal:5380
DEPLOYWERK_TECHNITIUM_API_TOKEN=ReplaceWithTechnitiumDnsApiToken

DEPLOYWERK_PORTAINER_INTEGRATION_ENABLED=true
DEPLOYWERK_PORTAINER_API_URL=https://host.docker.internal:9443
DEPLOYWERK_PORTAINER_API_TOKEN=ptr_ReplaceWithPortainerAccessToken

AUTHENTIK_SECRET_KEY=authentik-secret-key-minimum-fifty-characters-long-change-me-in-production-please
AUTHENTIK_POSTGRES_PASSWORD=authentik-postgres-password-change-me
