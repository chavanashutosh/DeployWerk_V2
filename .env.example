# Copy to .env in the repo root (optional). deploywerk-api loads .env from cwd.

# SQLite database file (created automatically)
DATABASE_URL=sqlite:deploywerk.db?mode=rwc

# Required in production — use a long random secret
JWT_SECRET=change-me-in-production

# development | production — production disables demo seeding and demo password exposure
APP_ENV=development

# Seed demo users (owner/admin/member) — forced off when APP_ENV=production
SEED_DEMO_USERS=true

# API includes plaintext demo passwords in GET /api/v1/bootstrap — forced off when APP_ENV=production
DEMO_LOGINS_PUBLIC=true

HOST=127.0.0.1
PORT=8080
