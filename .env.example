# DeployWerk — copy to `.env` in the repo root (optional). deploywerk-api loads `.env` from cwd.
#
# Local minimum: DATABASE_URL, JWT_SECRET, HOST, and PORT (below) are enough for typical dev; other
# variables have safe defaults or are optional until you enable a feature (see sections).
#
# Production (APP_ENV=production): set SERVER_KEY_ENCRYPTION_KEY (32 bytes, hex or base64) or the API
# panics. Set JWT_SECRET to a long random value (do not rely on the dev fallback).
#
# Optional: Authentik/OIDC, SCIM, payments webhooks, GitHub App, platform Docker — enable per section.

# --- Logging (API, deploy worker, agent — tracing / env_logger filter) ---
# RUST_LOG=deploywerk_api=info,tower_http=info

# PostgreSQL. Local default matches docker-compose.yml; override if your DB differs.
DATABASE_URL=postgresql://deploywerk:deploywerk@127.0.0.1:5432/deploywerk

# Optional: max connections for sqlx pool (default 10)
# DATABASE_MAX_CONNECTIONS=10

# Optional: per-connection statement timeout in ms (aborts runaway queries; numeric env only).
# DATABASE_STATEMENT_TIMEOUT_MS=30000

# Long random secret (required in production). Example: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# 32-byte AES key for SSH private keys at rest (64 hex chars or 32-byte base64). Required when APP_ENV=production.
# Generate: `openssl rand -hex 32` — in development you may omit (key is derived from JWT_SECRET with a warning).
# SERVER_KEY_ENCRYPTION_KEY=

# development | production — production disables demo seeding and demo password exposure
APP_ENV=development

# Seed demo users (owner/admin/member) — forced off when APP_ENV=production
SEED_DEMO_USERS=true

# API includes plaintext demo passwords in GET /api/v1/bootstrap — forced off when APP_ENV=production
DEMO_LOGINS_PUBLIC=true

HOST=127.0.0.1
PORT=8080

# --- MinIO (docker compose `minio` / `minio-init`) ---
# Optional overrides for Compose interpolation (defaults match docker-compose.yml).
# If you change these, set API `DEPLOYWERK_DEFAULT_STORAGE_*` to the same access key/secret/bucket for the `api` service.
# DEPLOYWERK_MINIO_ROOT_USER=deploywerk
# DEPLOYWERK_MINIO_ROOT_PASSWORD=deploywerk-dev-only-change-me
# DEPLOYWERK_MINIO_BUCKET=deploywerk

# --- CLI + Agent ---
# Base URL for `deploywerk` CLI (global --base-url) and deploywerk-agent heartbeats.
# Must match API listen address (HOST/PORT above), e.g. PORT=8080 → http://127.0.0.1:8080
DEPLOYWERK_API_URL=http://127.0.0.1:8080
# Required to run deploywerk-agent; obtain from team Agent registration in the UI. Never commit real tokens.
# DEPLOYWERK_AGENT_TOKEN=

# Optional: Stripe webhook signing secret (whsec_…). If unset, webhook body is logged only.
# STRIPE_WEBHOOK_SECRET=

# Optional: Adyen webhook HMAC key (hex from Customer Area). If set, POST /api/v1/hooks/adyen verifies signatures.
# ADYEN_HMAC_KEY_HEX=

# Optional: grant platform admin on startup (user must already exist). Demo seed also promotes demo owner.
# DEPLOYWERK_BOOTSTRAP_PLATFORM_ADMIN_EMAIL=owner@demo.deploywerk.local

# Optional: shown in GET /api/v1/admin/system
# DEPLOYWERK_GIT_SHA=

# Optional: HTTPS URL to POST JSON { team_id, purge_id, paths } after recording a CDN purge.
# DEPLOYWERK_CDN_PURGE_WEBHOOK_URL=

# --- Authentik (OIDC + SCIM-driven RBAC) ---
# When AUTHENTIK_ISSUER is set, GET /api/v1/auth/oidc/config exposes the provider and POST /api/v1/auth/oidc/callback accepts codes.
# For OIDC, set ISSUER, CLIENT_ID, CLIENT_SECRET, and REDIRECT_URI together.
# Issuer is the OpenID "issuer" base (e.g. https://authentik.example.com/application/o/deploywerk/).
# AUTHENTIK_ISSUER=
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
# Must match the redirect URI registered on the Authentik OAuth2 provider (SPA URL).
# AUTHENTIK_REDIRECT_URI=http://127.0.0.1:5173/login/oidc/callback
# Optional: full Authentik admin UI URL for bootstrap / login links (overrides derived URL).
# AUTHENTIK_ADMIN_URL=http://127.0.0.1:9000/if/admin/
# Optional: Authentik origin if issuer path is non-standard (default derives host from AUTHENTIK_ISSUER).
# AUTHENTIK_BROWSER_BASE_URL=http://127.0.0.1:9000

# When false, email/password login and register are disabled (production with SSO only).
# ALLOW_LOCAL_PASSWORD_AUTH=true

# SCIM 2.0 base URL: https://api.example.com/scim/v2 — Authentik outbound SCIM uses Authorization: Bearer <token>
# DEPLOYWERK_SCIM_BEARER_TOKEN=
# Optional override for users.idp_issuer on SCIM-provisioned users (defaults to AUTHENTIK_ISSUER)
# DEPLOYWERK_SCIM_IDP_ISSUER=

# Optional docker compose --profile authentik (see docker-compose.yml)
# AUTHENTIK_SECRET_KEY=generate-a-long-random-string
# AUTHENTIK_POSTGRES_PASSWORD=authentik
# Operator logs (not shown in DeployWerk UI): docker compose --profile authentik logs -f authentik-server authentik-worker

# --- GitHub App (PR preview webhooks) ---
# HMAC secret for POST /api/v1/hooks/github-app (same signing as repo webhooks: X-Hub-Signature-256).
# GITHUB_APP_WEBHOOK_SECRET=
# Public slug for https://github.com/apps/<slug>/installations/new (GET .../github-app/install-url).
# GITHUB_APP_SLUG=
# Optional: RS256 JWT for GitHub installation access-token API (webhooks still use HMAC above).
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/app.pem
# Optional: create a dedicated Docker network per PR preview container (plus Traefik network when edge=traefik).
# DEPLOYWERK_PR_PREVIEW_ISOLATED_NETWORK=false

# --- Transactional email (SMTP) ---
# When DEPLOYWERK_SMTP_HOST and DEPLOYWERK_SMTP_FROM are set, the API can send invitation mail and
# notification endpoints of kind "email" (recipient address in target_url).
# DEPLOYWERK_SMTP_HOST=smtp.example.com
# DEPLOYWERK_SMTP_PORT=587
# DEPLOYWERK_SMTP_USER=
# DEPLOYWERK_SMTP_PASSWORD=
# DEPLOYWERK_SMTP_FROM=DeployWerk <noreply@example.com>
# starttls | wrapper | none — default starttls; port 465 defaults to wrapper unless overridden.
# DEPLOYWERK_SMTP_TLS=starttls
# Optional: enable the Mail Platform Phase 1 endpoints (team mail domains + /mail/send).
# DEPLOYWERK_MAIL_ENABLED=true
#
# Local dev (docker compose) with Stalwart Mail Server (see README.md § Mail):
# DEPLOYWERK_SMTP_HOST=stalwart
# DEPLOYWERK_SMTP_PORT=587
# DEPLOYWERK_SMTP_TLS=starttls
# DEPLOYWERK_SMTP_FROM=DeployWerk <noreply@dev.local>
# DEPLOYWERK_SMTP_USER=deploywerk
# DEPLOYWERK_SMTP_PASSWORD=deploywerk-dev-only-change-me
# Public web UI base URL for invite links in email (e.g. https://app.example.com).
# DEPLOYWERK_PUBLIC_APP_URL=https://app.example.com
# When true, send best-effort email after super-admin grant/revoke and operator billing updates (requires SMTP above).
# DEPLOYWERK_ADMIN_ACTION_EMAILS=false

# --- Web (Vite) ---
# When true, /pricing requires login (build-time).
# VITE_PRICING_REQUIRES_AUTH=false
#
# Optional: absolute API origin for built static assets (npm run build / preview). No trailing slash.
# When unset, the app uses relative /api URLs (needs Vite dev/preview proxy or reverse proxy).
# VITE_API_URL=http://127.0.0.1:8080
#
# Optional: where Vite dev server and `vite preview` proxy /api (default http://127.0.0.1:8080).
# Set to match API PORT/HOST if not on 8080.
# DEPLOYWERK_API_PROXY=http://127.0.0.1:8080

# --- Mollie ---
# MOLLIE_API_KEY=test_... or live_...
# Webhook: POST /api/v1/mollie/webhook — payment id is verified via Mollie API.

# --- Platform Docker (API host) + auto hostnames ---
# When true, teams get a built-in "Platform (API host)" destination and deploy jobs run `docker` locally (high privilege).
# DEPLOYWERK_PLATFORM_DOCKER_ENABLED=false
# Wildcard DNS should point *.DEPLOYWERK_APPS_BASE_DOMAIN at your edge (e.g. Traefik).
# DEPLOYWERK_APPS_BASE_DOMAIN=apps.example.com
# none | traefik — when traefik, `docker run` adds labels and attaches to DEPLOYWERK_TRAEFIK_DOCKER_NETWORK.
# DEPLOYWERK_EDGE_MODE=none
# DEPLOYWERK_TRAEFIK_DOCKER_NETWORK=traefik
# Port your app images expose (Traefik service port).
# DEPLOYWERK_APP_CONTAINER_PORT=8080

# --- Deploy job dispatch ---
# inline (default): API process runs deploy jobs after enqueue.
# external: jobs stay queued; run `cargo run -p deploywerk-api --bin deploywerk-deploy-worker` (same DATABASE_URL + keys).
# DEPLOYWERK_DEPLOY_DISPATCH=inline
# Poll interval when the queue is empty (deploy worker binary only).
# DEPLOYWERK_WORKER_POLL_MS=2000

# --- Platform integrations (links in UI + GET /api/v1/bootstrap) ---
# Same-host Docker stack: one flag fills typical 127.0.0.1 URLs (Traefik :8080, Portainer :9443, Forgejo :3000,
# Technitium :5380, Mailcow :8444). Unset slots stay overridable with DEPLOYWERK_INTEGRATION_* below.
# DEPLOYWERK_LOCAL_SERVICE_DEFAULTS=true
# Optional per-service overrides (any set value replaces the preset for that slot only):
# DEPLOYWERK_INTEGRATION_FORGEJO_URL=  DEPLOYWERK_INTEGRATION_MAILCOW_URL=  DEPLOYWERK_INTEGRATION_PORTAINER_URL=
# DEPLOYWERK_INTEGRATION_TECHNITIUM_URL=  DEPLOYWERK_INTEGRATION_MATRIX_CLIENT_URL=  DEPLOYWERK_INTEGRATION_TRAEFIK_URL=
# Optional: SSO section link becomes {base}/README.md#single-sign-on-oidc when set; else in-app /app/sso-setup.
# DEPLOYWERK_DOCUMENTATION_BASE_URL=

# --- Optional Technitium DNS API (automation stub; default off) ---
# DEPLOYWERK_TECHNITIUM_DNS_ENABLED=false
# DEPLOYWERK_TECHNITIUM_API_URL=https://dns.example.com:5380
# DEPLOYWERK_TECHNITIUM_API_TOKEN=

# --- Optional Portainer read-only API probe (platform admin; default off) ---
# DEPLOYWERK_PORTAINER_INTEGRATION_ENABLED=false
# API base (defaults to DEPLOYWERK_INTEGRATION_PORTAINER_URL if unset).
# DEPLOYWERK_PORTAINER_API_URL=https://portainer.example.com:9443
# DEPLOYWERK_PORTAINER_API_TOKEN=
